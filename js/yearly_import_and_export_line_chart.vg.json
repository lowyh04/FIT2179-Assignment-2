{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "description": "A line chart showing Malaysia's yearly imports and exports from 2019 to 2025 in Ringgit Malaysia (RM).",
    "width": 800,
    "height": 600,
    "data": {
    "url": "data/yearly-import-and-export-(2019-2025).csv"
    },
    "transform": [
        {
            "fold": ["Sum_of_exports(RM Billion)", "Sum_of_imports(RM Billion)"],
            "as": ["Trade Type", "Value (RM Billion)"]
        },
        {
            "calculate": "datum['Trade Type'] == 'Sum_of_exports(RM Billion)' ? 'Exports' : 'Imports'",
            "as": "Trade Category"
        }
    ],
    "layer": [
        {
            "mark": {
                "type": "line",
                "point": {
                "filled": true,
                "size": 80
                },
                "strokeWidth": 3
            },
            "encoding": {
                "x": {
                "field": "Year",
                "type": "ordinal",
                "title": "Year",
                "axis": {"labelAngle": 0, "labelPadding": 10}
                },
                "y": {"field": "Value (RM Billion)", "type": "quantitative", "title": "Value (RM Billion)", "axis": {"tickMinStep": 100}},
                "color": {
                    "field": "Trade Category",
                    "type": "nominal",
                    "title": "Trade Type",
                    "legend": {
                        "orient": "top-left",
                        "direction": "horizontal",
                        "titleFontWeight":"bold",
                        "titleFontSize": 12,
                        "labelFontSize": 12
                    }
                },
                "tooltip": [
                    {"field": "Year", "type": "ordinal"},
                    {"field": "Trade Category", "type": "nominal"},
                    {"field": "Value (RM Billion)", "type": "quantitative","format": ",.2f"}
                    ]
                }
            },
            {
                "transform": [{"filter": "datum.Year == '2023' && datum['Trade Category'] == 'Imports'"}],
                "mark": {"type": "rule", "strokeWidth": 1.5, "stroke": "#444"},
                "encoding": {
                    "x": {"field": "Year", "type": "ordinal"},
                    "y": {"field": "Value (RM Billion)", "type": "quantitative"},
                    "x2": {"value": 400},
                    "y2": {"value": 230}
                }
            },
            {
                "transform": [{"filter": "datum.Year == '2023' && datum['Trade Category'] == 'Exports'"}],
                "mark": {"type": "rule", "strokeWidth": 1.5, "stroke": "#444"},
                "encoding": {
                    "x": {"field": "Year", "type": "ordinal"},
                    "y": {"field": "Value (RM Billion)", "type": "quantitative"},
                    "x2": {"value": 400},
                    "y2": {"value": 230}
                }
            },
            {
                "transform": [{"filter": "datum.Year == '2023' && datum['Trade Category'] == 'Imports'"}],
                "mark": {"type": "text", "align": "left", "dx": -240, "dy": 110, "fontSize": 13, "fontWeight": "bold", "color": "#444", "lineBreak": "\n"},
                "encoding": {
                    "x": {"field": "Year", "type": "ordinal"},
                    "y": {"field": "Value (RM Billion)", "type": "quantitative"},
                    "text": {"value": "Imports and exports value declined in 2023\ndue to global conflicts and economic uncertainty"}
                }
            }
    ]
}