{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 800,
  "height": 600,
  "data": {
    "url": "data/Malaysia-Trade-Balance-and-Trade-To-GDP-Ratio.csv"
  },
  "layer": [
    {
      "transform": [{"calculate": "'Trade Balance'", "as": "Series"}],
      "mark": {
        "type": "bar",
        "size": 40,
        "color": "#2A9D8F",
        "opacity": 0.75
    },
      "encoding": {
        "x": {"field": "Year", "type": "ordinal", "title": "Year"},
        "y": { "field": "Trade Balance(USD Billion)", "type": "quantitative", "title": "Trade Balance (USD Billion)"},
        "color": {
          "field": "Series",
          "type": "nominal",
          "scale": {
            "domain": ["Trade Balance", "Trade-to-GDP Ratio"],
            "range": ["#2A9D8F", "#6A4C93"]
          },
          "legend": {"title": "Indicator"}
        },
        "tooltip": [
          {"field": "Year"},
          {"field": "Trade Balance(USD Billion)", "format": ".2f"}
        ]
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#6A4C93",
        "point": {
            "filled": true,
            "size": 80,
            "color": "#6B3C73"
        },
        "strokeWidth": 3
      },
      "encoding": {
        "x": {"field": "Year", "type": "ordinal"},
        "y": {"field": "Trade to GDP Ratio(%)", "type": "quantitative", "title": "Trade-to-GDP Ratio (%)"},
        "tooltip": [
          {"field": "Year"},
          {"field": "Trade to GDP Ratio(%)", "format": ".2f"}
        ]
      }
    }
  ],
  "resolve": {"scale": {"y": "independent"}}
}